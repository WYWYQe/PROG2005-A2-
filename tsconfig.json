{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "outFile": "./app.js",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "verbatimModuleSyntax": false,
    "sourceMap": false,
    "declaration": false
  },
  "include": ["src/app.ts"]
}